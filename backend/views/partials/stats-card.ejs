<%
// Expected locals: title, value, change, changeType ('up'|'down'), icon, color, href
// color options: 'blue', 'emerald', 'violet', 'amber'
const colorMap = {
  blue:    { bg: 'bg-blue-50 dark:bg-blue-900/20',   icon: 'text-blue-500',   ring: 'ring-blue-100 dark:ring-blue-900/40',   badge: 'bg-blue-100 dark:bg-blue-900/40 text-blue-700 dark:text-blue-300' },
  emerald: { bg: 'bg-emerald-50 dark:bg-emerald-900/20', icon: 'text-emerald-500', ring: 'ring-emerald-100 dark:ring-emerald-900/40', badge: 'bg-emerald-100 dark:bg-emerald-900/40 text-emerald-700 dark:text-emerald-300' },
  violet:  { bg: 'bg-violet-50 dark:bg-violet-900/20',  icon: 'text-violet-500',  ring: 'ring-violet-100 dark:ring-violet-900/40',  badge: 'bg-violet-100 dark:bg-violet-900/40 text-violet-700 dark:text-violet-300' },
  amber:   { bg: 'bg-amber-50 dark:bg-amber-900/20',   icon: 'text-amber-500',   ring: 'ring-amber-100 dark:ring-amber-900/40',   badge: 'bg-amber-100 dark:bg-amber-900/40 text-amber-700 dark:text-amber-300' },
};
const c = colorMap[color] || colorMap.blue;
const isUp = changeType !== 'down';
%>
<div class="card-hover bg-white dark:bg-gray-900 rounded-2xl p-5 border border-gray-200 dark:border-gray-800 shadow-sm flex flex-col gap-4 cursor-default">
  <div class="flex items-start justify-between">
    <div class="flex-1 min-w-0">
      <p class="text-xs font-semibold text-gray-400 dark:text-gray-500 uppercase tracking-wider truncate"><%= title %></p>
      <p class="mt-1.5 text-2xl font-bold text-gray-900 dark:text-white tracking-tight"><%= typeof value !== 'undefined' ? value.toLocaleString() : '—' %></p>
    </div>
    <div class="<%= c.bg %> <%= c.ring %> ring-1 p-2.5 rounded-xl flex-shrink-0 ml-3">
      <span class="<%= c.icon %> text-xl leading-none"><%= icon %></span>
    </div>
  </div>
  <div class="flex items-center gap-2">
    <span class="inline-flex items-center gap-1 text-xs font-semibold px-2 py-0.5 rounded-full
      <%= isUp ? 'bg-emerald-100 dark:bg-emerald-900/40 text-emerald-700 dark:text-emerald-300' : 'bg-red-100 dark:bg-red-900/40 text-red-600 dark:text-red-400' %>">
      <span><%= isUp ? '↑' : '↓' %></span>
      <span><%= Math.abs(change) %>%</span>
    </span>
    <span class="text-xs text-gray-400 dark:text-gray-500">vs last month</span>
  </div>
</div>
