<%
// locals: user (object), stats { totalChats, totalMessages, lastActive }
const u = typeof user !== 'undefined' ? user : {};
const st = typeof userStats !== 'undefined' ? userStats : {};
%>

<div class="space-y-6 max-w-5xl">

  <!-- Back + Actions Bar -->
  <div class="flex items-center justify-between gap-4 flex-wrap">
    <a href="/admin/users" class="inline-flex items-center gap-2 text-sm text-gray-500 dark:text-gray-400 hover:text-gray-800 dark:hover:text-gray-200 transition-colors font-medium">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
      Back to Users
    </a>
    <div class="flex items-center gap-2">
      <a href="/admin/users/<%= u._id %>/edit" class="inline-flex items-center gap-2 px-4 py-2 text-sm font-semibold text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-xl hover:bg-gray-50 dark:hover:bg-gray-800 transition-colors shadow-sm">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
        Edit User
      </a>
      <% if (!u.isBlocked) { %>
      <button onclick="openModal('banModal')" class="inline-flex items-center gap-2 px-4 py-2 text-sm font-semibold text-white bg-amber-500 hover:bg-amber-600 rounded-xl transition-colors shadow-sm">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636"/></svg>
        Ban User
      </button>
      <% } else { %>
      <form method="POST" action="/admin/users/<%= u._id %>/unban">
        <button type="submit" class="inline-flex items-center gap-2 px-4 py-2 text-sm font-semibold text-white bg-emerald-500 hover:bg-emerald-600 rounded-xl transition-colors shadow-sm">Unban User</button>
      </form>
      <% } %>
      <button onclick="openModal('deleteModal')" class="inline-flex items-center gap-2 px-4 py-2 text-sm font-semibold text-white bg-red-600 hover:bg-red-700 rounded-xl transition-colors shadow-sm">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
        Delete
      </button>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-5">

    <!-- Left: Profile Card -->
    <div class="lg:col-span-1 space-y-5">

      <!-- Avatar + Identity -->
      <div class="bg-white dark:bg-gray-900 rounded-2xl border border-gray-200 dark:border-gray-800 shadow-sm p-6 text-center">
        <div class="w-20 h-20 mx-auto rounded-2xl bg-gradient-to-br from-brand-400 to-brand-700 flex items-center justify-center shadow-lg mb-4">
          <span class="text-white text-3xl font-bold"><%= u.fullName ? u.fullName.charAt(0).toUpperCase() : '?' %></span>
        </div>
        <h2 class="text-lg font-bold text-gray-900 dark:text-white"><%= u.fullName || '—' %></h2>
        <p class="text-sm text-gray-400 font-mono mt-0.5">@<%= u.username || 'N/A' %></p>

        <!-- Status Badges -->
        <div class="flex items-center justify-center gap-2 mt-3 flex-wrap">
          <% if (u.isBlocked) { %>
            <span class="status-badge bg-red-100 dark:bg-red-900/30 text-red-600 dark:text-red-400"><span class="w-1.5 h-1.5 bg-red-500 rounded-full mr-1"></span>Banned</span>
          <% } else { %>
            <span class="status-badge bg-emerald-100 dark:bg-emerald-900/30 text-emerald-600 dark:text-emerald-400"><span class="w-1.5 h-1.5 bg-emerald-500 rounded-full mr-1 animate-pulse"></span>Active</span>
          <% } %>
          <% if (u.isVerified) { %>
            <span class="status-badge bg-blue-100 dark:bg-blue-900/30 text-blue-600 dark:text-blue-400">✓ Verified</span>
          <% } else { %>
            <span class="status-badge bg-gray-100 dark:bg-gray-800 text-gray-400">Unverified</span>
          <% } %>
        </div>

        <!-- Provider -->
        <div class="mt-4 pt-4 border-t border-gray-100 dark:border-gray-800">
          <span class="text-xs text-gray-400 block mb-1">Sign-in Provider</span>
          <span class="text-sm font-semibold text-gray-700 dark:text-gray-300 capitalize">
            <%= u.provider === 'google' ? '🔴 Google OAuth' : '📧 Email / Password' %>
          </span>
        </div>
      </div>

      <!-- Account Info -->
      <div class="bg-white dark:bg-gray-900 rounded-2xl border border-gray-200 dark:border-gray-800 shadow-sm p-5">
        <h3 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-4">Account Information</h3>
        <dl class="space-y-3">
          <div class="flex items-start justify-between gap-2">
            <dt class="text-xs text-gray-400 flex-shrink-0">Email</dt>
            <dd class="text-xs font-medium text-gray-700 dark:text-gray-300 text-right break-all"><%= u.email || '—' %></dd>
          </div>
          <div class="flex items-start justify-between gap-2">
            <dt class="text-xs text-gray-400 flex-shrink-0">User ID</dt>
            <dd class="text-xs font-mono text-gray-500 dark:text-gray-500 text-right truncate max-w-[120px]" title="<%= u._id %>"><%= u._id %></dd>
          </div>
          <div class="flex items-start justify-between gap-2">
            <dt class="text-xs text-gray-400 flex-shrink-0">Joined</dt>
            <dd class="text-xs font-medium text-gray-700 dark:text-gray-300">
              <%= u.createdAt ? new Date(u.createdAt).toLocaleDateString('en-IN', { day:'2-digit', month:'long', year:'numeric' }) : '—' %>
            </dd>
          </div>
          <div class="flex items-start justify-between gap-2">
            <dt class="text-xs text-gray-400 flex-shrink-0">Last Active</dt>
            <dd class="text-xs font-medium text-gray-700 dark:text-gray-300">
              <%= st.lastActive ? new Date(st.lastActive).toLocaleDateString('en-IN', { day:'2-digit', month:'short', year:'numeric' }) : 'Never' %>
            </dd>
          </div>
          <div class="flex items-start justify-between gap-2">
            <dt class="text-xs text-gray-400 flex-shrink-0">Verified</dt>
            <dd class="text-xs font-semibold <%= u.isVerified ? 'text-emerald-500' : 'text-gray-400' %>"><%= u.isVerified ? 'Yes' : 'No' %></dd>
          </div>
          <div class="flex items-start justify-between gap-2">
            <dt class="text-xs text-gray-400 flex-shrink-0">Banned</dt>
            <dd class="text-xs font-semibold <%= u.isBlocked ? 'text-red-500' : 'text-gray-400' %>"><%= u.isBlocked ? 'Yes' : 'No' %></dd>
          </div>
        </dl>
      </div>
    </div>

    <!-- Right: Stats + Activity -->
    <div class="lg:col-span-2 space-y-5">

      <!-- Stats Cards -->
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        <div class="bg-white dark:bg-gray-900 rounded-2xl border border-gray-200 dark:border-gray-800 shadow-sm p-5 text-center card-hover">
          <p class="text-2xl font-bold text-gray-900 dark:text-white"><%= (st.totalChats || 0).toLocaleString() %></p>
          <p class="text-xs text-gray-400 mt-1 font-medium uppercase tracking-wide">Total Chats</p>
        </div>
        <div class="bg-white dark:bg-gray-900 rounded-2xl border border-gray-200 dark:border-gray-800 shadow-sm p-5 text-center card-hover">
          <p class="text-2xl font-bold text-gray-900 dark:text-white"><%= (st.totalMessages || 0).toLocaleString() %></p>
          <p class="text-xs text-gray-400 mt-1 font-medium uppercase tracking-wide">Total Messages</p>
        </div>
        <div class="bg-white dark:bg-gray-900 rounded-2xl border border-gray-200 dark:border-gray-800 shadow-sm p-5 text-center card-hover">
          <p class="text-2xl font-bold text-gray-900 dark:text-white">
            <%= st.lastActive ? new Date(st.lastActive).toLocaleDateString('en-IN', { day:'2-digit', month:'short' }) : '—' %>
          </p>
          <p class="text-xs text-gray-400 mt-1 font-medium uppercase tracking-wide">Last Active</p>
        </div>
      </div>

      <!-- Recent Chats -->
      <div class="bg-white dark:bg-gray-900 rounded-2xl border border-gray-200 dark:border-gray-800 shadow-sm overflow-hidden">
        <div class="px-5 py-4 border-b border-gray-100 dark:border-gray-800">
          <h3 class="text-sm font-semibold text-gray-800 dark:text-white">Recent Chats</h3>
          <p class="text-xs text-gray-400 mt-0.5">Last conversations by this user</p>
        </div>
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-gray-100 dark:border-gray-800 bg-gray-50 dark:bg-gray-800/50">
                <th class="px-5 py-3 text-left text-xs font-semibold text-gray-400 uppercase tracking-wider">Title</th>
                <th class="px-5 py-3 text-left text-xs font-semibold text-gray-400 uppercase tracking-wider">Visibility</th>
                <th class="px-5 py-3 text-left text-xs font-semibold text-gray-400 uppercase tracking-wider">Created</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-100 dark:divide-gray-800">
              <% if (typeof recentChats !== 'undefined' && recentChats && recentChats.length > 0) { %>
                <% recentChats.forEach(function(chat) { %>
                <tr class="hover:bg-gray-50 dark:hover:bg-gray-800/40 transition-colors">
                  <td class="px-5 py-3 font-medium text-gray-700 dark:text-gray-300 truncate max-w-[200px]"><%= chat.title || 'Untitled Chat' %></td>
                  <td class="px-5 py-3">
                    <% if (chat.isPublic) { %>
                      <span class="status-badge bg-blue-100 dark:bg-blue-900/30 text-blue-600 dark:text-blue-400">Public</span>
                    <% } else { %>
                      <span class="status-badge bg-gray-100 dark:bg-gray-800 text-gray-400">Private</span>
                    <% } %>
                  </td>
                  <td class="px-5 py-3 text-xs text-gray-400 whitespace-nowrap"><%= new Date(chat.createdAt).toLocaleDateString('en-IN', { day:'2-digit', month:'short', year:'numeric' }) %></td>
                </tr>
                <% }); %>
              <% } else { %>
              <tr>
                <td colspan="3" class="px-5 py-8 text-center text-sm text-gray-400">No chats found for this user</td>
              </tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>

      <!-- Timeline / Activity Log placeholder -->
      <div class="bg-white dark:bg-gray-900 rounded-2xl border border-gray-200 dark:border-gray-800 shadow-sm p-5">
        <h3 class="text-sm font-semibold text-gray-800 dark:text-white mb-4">Account Timeline</h3>
        <div class="relative pl-5 border-l-2 border-gray-100 dark:border-gray-800 space-y-5">
          <div class="relative">
            <div class="absolute -left-[1.375rem] top-0.5 w-3.5 h-3.5 rounded-full bg-brand-500 ring-4 ring-white dark:ring-gray-900"></div>
            <p class="text-xs font-semibold text-gray-700 dark:text-gray-300">Account Created</p>
            <p class="text-xs text-gray-400 mt-0.5"><%= u.createdAt ? new Date(u.createdAt).toLocaleString('en-IN') : '—' %></p>
          </div>
          <% if (u.isVerified) { %>
          <div class="relative">
            <div class="absolute -left-[1.375rem] top-0.5 w-3.5 h-3.5 rounded-full bg-emerald-500 ring-4 ring-white dark:ring-gray-900"></div>
            <p class="text-xs font-semibold text-gray-700 dark:text-gray-300">Email Verified</p>
            <p class="text-xs text-gray-400 mt-0.5">Account verification completed</p>
          </div>
          <% } %>
          <% if (u.isBlocked) { %>
          <div class="relative">
            <div class="absolute -left-[1.375rem] top-0.5 w-3.5 h-3.5 rounded-full bg-red-500 ring-4 ring-white dark:ring-gray-900"></div>
            <p class="text-xs font-semibold text-red-500">Account Banned</p>
            <p class="text-xs text-gray-400 mt-0.5">User was banned by administrator</p>
          </div>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Ban Modal -->
<div id="banModal" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4">
  <div class="absolute inset-0 bg-black/50 backdrop-blur-sm" onclick="closeModal('banModal')"></div>
  <div class="relative z-10 bg-white dark:bg-gray-900 rounded-2xl shadow-2xl w-full max-w-md border border-gray-200 dark:border-gray-800 animate-fade-in overflow-hidden">
    <div class="px-6 pt-6 pb-4 flex items-start gap-4">
      <div class="flex-shrink-0 w-10 h-10 rounded-full bg-amber-100 dark:bg-amber-900/30 flex items-center justify-center">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-amber-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636"/></svg>
      </div>
      <div>
        <h3 class="text-base font-semibold text-gray-900 dark:text-white">Ban User</h3>
        <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">Are you sure you want to ban <strong class="text-gray-700 dark:text-gray-200"><%= u.fullName %></strong>? They will immediately lose access.</p>
      </div>
    </div>
    <div class="h-px bg-gray-100 dark:bg-gray-800 mx-6"></div>
    <div class="px-6 py-4 flex justify-end gap-3">
      <button onclick="closeModal('banModal')" class="px-4 py-2 text-sm font-medium text-gray-700 dark:text-gray-300 bg-gray-100 dark:bg-gray-800 hover:bg-gray-200 dark:hover:bg-gray-700 rounded-xl transition-colors">Cancel</button>
      <form method="POST" action="/admin/users/<%= u._id %>/ban">
        <button type="submit" class="px-4 py-2 text-sm font-semibold text-white bg-amber-500 hover:bg-amber-600 rounded-xl transition-colors shadow-sm">Confirm Ban</button>
      </form>
    </div>
  </div>
</div>

<!-- Delete Modal -->
<div id="deleteModal" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4">
  <div class="absolute inset-0 bg-black/50 backdrop-blur-sm" onclick="closeModal('deleteModal')"></div>
  <div class="relative z-10 bg-white dark:bg-gray-900 rounded-2xl shadow-2xl w-full max-w-md border border-gray-200 dark:border-gray-800 animate-fade-in overflow-hidden">
    <div class="px-6 pt-6 pb-4 flex items-start gap-4">
      <div class="flex-shrink-0 w-10 h-10 rounded-full bg-red-100 dark:bg-red-900/30 flex items-center justify-center">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-red-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
      </div>
      <div>
        <h3 class="text-base font-semibold text-gray-900 dark:text-white">Delete User</h3>
        <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">Delete <strong class="text-gray-700 dark:text-gray-200"><%= u.fullName %></strong> and all their data permanently. <span class="text-red-500 font-medium">This cannot be undone.</span></p>
      </div>
    </div>
    <div class="h-px bg-gray-100 dark:bg-gray-800 mx-6"></div>
    <div class="px-6 py-4 flex justify-end gap-3">
      <button onclick="closeModal('deleteModal')" class="px-4 py-2 text-sm font-medium text-gray-700 dark:text-gray-300 bg-gray-100 dark:bg-gray-800 hover:bg-gray-200 dark:hover:bg-gray-700 rounded-xl transition-colors">Cancel</button>
      <form method="POST" action="/admin/users/<%= u._id %>/delete">
        <button type="submit" class="px-4 py-2 text-sm font-semibold text-white bg-red-600 hover:bg-red-700 rounded-xl transition-colors shadow-sm">Delete User</button>
      </form>
    </div>
  </div>
</div>
